# Path to the target git repo where commits will be made
REPO_PATH=./dummy-repo

# GitHub remote name
GIT_REMOTE=origin

# Branch to push to
GIT_BRANCH=main

# Cron schedule (default: every day at 9am)
CRON_SCHEDULE=0 9 * * *

# Backfill: start date (YYYY-MM-DD)
BACKFILL_START=2024-01-01

# Backfill: end date (YYYY-MM-DD), leave empty to use today
BACKFILL_END=

# Git user name (optional, uses repo config if not set)
GIT_USER_NAME=

# Git user email (optional, uses repo config if not set)
GIT_USER_EMAIL=
